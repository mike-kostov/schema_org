defmodule SchemaOrg.<%= module_name %> do
  @moduledoc <%= inspect(moduledoc, printable_limit: :infinity) %>

  defstruct [<%= Enum.map_join(properties, ", ", fn p -> inspect(p.field) end) %>]

  @json_keys %{<%= Enum.map_join(properties, ", ", fn p -> "#{p.func}: #{inspect(p.json_key)}" end) %>}

  @doc false
  def __schema_org__, do: %{type: <%= inspect(schema_type) %>, json_keys: @json_keys}

  @doc "Builds an empty `SchemaOrg.<%= module_name %>` struct."
  def new, do: %__MODULE__{}
end
